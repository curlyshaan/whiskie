# Whiskie environment template
# Keep this file grouped and readable.
# Docs:
# - Quatarly: https://www.quatarly.cloud/docs
# - FMP Stable API: https://site.financialmodelingprep.com/developer/docs/stable
# - Tavily: https://docs.tavily.com/welcome
# - Tradier: https://documentation.tradier.com/brokerage-api
# - Resend: https://resend.com/docs

# -----------------------------------------------------------------------------
# AI providers
# -----------------------------------------------------------------------------
QUATARLY_API_KEY=your_quatarly_api_key
QUATARLY_BASE_URL=https://api.quatarly.cloud/
TAVILY_API_KEY=your_tavily_key

# -----------------------------------------------------------------------------
# Market data
# -----------------------------------------------------------------------------
FMP_API_KEY_1=your_fmp_key

# -----------------------------------------------------------------------------
# Brokerage
# -----------------------------------------------------------------------------
TRADING_MODE=paper
TRADIER_API_KEY=your_tradier_live_key
TRADIER_BASE_URL=https://api.tradier.com/v1
TRADIER_SANDBOX_API_KEY=your_tradier_sandbox_key
TRADIER_SANDBOX_URL=https://sandbox.tradier.com/v1
TRADIER_ACCOUNT_ID=your_tradier_account_id
TRADIER_SANDBOX_ACCOUNT_ID=your_tradier_sandbox_account_id

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host:5432/dbname

# -----------------------------------------------------------------------------
# Email
# -----------------------------------------------------------------------------
RESEND_API_KEY=your_resend_key
RESEND_FROM_EMAIL=whiskie@yourdomain.com
ALERT_EMAIL=you@example.com

# -----------------------------------------------------------------------------
# Gemma MLB module
# -----------------------------------------------------------------------------
GEMMA_SGO_API_KEY=your_sports_game_odds_key
GEMMA_SGO_BASE_URL=https://sportsgameodds.com/api/v1
GEMMA_OPENWEATHER_API_KEY=your_openweather_key
GEMMA_OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5
GEMMA_CLAUDE_MODEL=claude-opus-4-6-thinking
GEMMA_CLAUDE_THINKING_BUDGET=35000
GEMMA_DEFAULT_EDGE_THRESHOLD=3
GEMMA_BANKROLL_UNITS=100
GEMMA_MAX_WAGER_UNITS=2
GEMMA_ODDS_REFRESH_INTERVAL_MIN=15

# -----------------------------------------------------------------------------
# Runtime mode
# -----------------------------------------------------------------------------
NODE_ENV=paper

# -----------------------------------------------------------------------------
# Risk and portfolio settings
# -----------------------------------------------------------------------------
INITIAL_CAPITAL=100000
MAX_POSITION_SIZE=0.12
MAX_PORTFOLIO_DRAWDOWN=0.20
MIN_CASH_RESERVE=0.10
CASH_WARNING_THRESHOLD=0.12
MAX_SECTOR_ALLOCATION=0.30
MAX_TOTAL_SHORT_EXPOSURE=0.25
