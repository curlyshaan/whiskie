{
  "name": "whiskie",
  "version": "1.0.0",
  "description": "AI-powered autonomous trading bot using Claude Opus",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "start:paper": "NODE_ENV=paper node src/index.js",
    "start:live": "NODE_ENV=production node src/index.js",
    "dev": "nodemon src/index.js",
    "db:init": "node src/db.js --init",
    "db:reset": "node scripts/reset-database.js",
    "populate-stocks": "node scripts/populate-stock-universe.js",
    "update-etb": "node scripts/update-etb-status.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "trading",
    "ai",
    "claude",
    "stocks",
    "automation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "cheerio": "^1.2.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "node-cron": "^3.0.3",
    "node-fetch": "^3.3.2",
    "pg": "^8.11.3",
    "resend": "^3.5.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
